# ============ 运行环境 ============
FLASK_ENV=production
SECRET_KEY=please-change-me-to-a-long-random-string

# ============ 对外地址 ============
# 本地调试用 :80；正式上线填你的已备案域名（Caddy 会自动签 HTTPS）
SITE_ADDRESS=:80
PUBLIC_BASE_URL=http://localhost

# ============ 后台 ============
# 店家登录后台用的密码，务必修改
ADMIN_PASSWORD=please-change-me

# ============ 数据库（MySQL，容器内） ============
MYSQL_DATABASE=youguo
MYSQL_USER=app
MYSQL_PASSWORD=please-change-me
MYSQL_ROOT_PASSWORD=please-change-me-root

# ============ 存储 ============
# MVP 用 local（本地卷）；第1期可换 s3（MinIO/OBS/OSS/COS/R2）
STORAGE_BACKEND=local

# ============ 微信服务号（第1期再用，MVP 留空） ============
# WECHAT_APPID=
# WECHAT_APPSECRET=

# ============ Gunicorn ============
GUNICORN_WORKERS=3
